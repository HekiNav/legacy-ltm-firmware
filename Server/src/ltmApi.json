{
    "name": "Helsinki Live Train Map API",
    "path":"/hki-ltm",
    "type":"docs",
    "methods": [
        {
            "path":"/{version}.json?mode={mode}",
            "desc":"JSON data consumed by the live train map",
            "version": {
                "type": "3-digit integer",
                "desc": "Firmware version of the board. Version x.y.z => xyz",
                "values": [
                    "100"
                ]
            },
            "mode": {
                "type": "string",
                "desc": "Display mode of the map",
                "values": [
                    "lines",
                    "delay",
                    "test",
                    "comp",
                    "train"
                ]
            },
            "examples": [
                {
                    "version":"100",
                    "mode":"lines"
                },
                {
                    "version":"100",
                    "mode":"test"
                }
            ]
        },
        {
            "path":"/most_delayed",
            "desc":"Gets the most delayed train on the live train map",
            "examples": [
                {}
            ]
        },
        {
            "path":"/ping?msg={message}",
            "desc":"Test method to see if the API is running correctly",
            "message": {
                "type": "string",
                "desc": "Test string to be echoed back by the server",
                "values": [
                    "any string"
                ]
            },
            "examples": [
                {
                    "message":"Hello World!"
                }
            ]
        },
        {
            "path":"/stats?stat={stat}",
            "desc":"Test method to see if the API is running correctly",
            "stat": {
                "type": "string",
                "desc": "Statistic id to get",
                "values": [
                    "local..{any endpoint path in the /hki-ltm api}",
                    "digitraffic..wss://rata.digitraffic.fi/mqtt",
                    "digitraffic..live-trains"
                ]
            },
            "examples": [
                {
                    "stat":"local../stats"
                },
                {
                    "stat":"local../100.json"
                },
                {
                    "stat":"digitraffic..wss://rata.digitraffic.fi/mqtt"
                }
            ]
        }
    ]
}